{
  "name": "personal-trainer",
  "version": "1.0.0",
  "description": "FORMA fitness operating system for planning, logging, nutrition, recovery, and coaching",
  "scripts": {
    "build": "node scripts/build.js",
    "build:inline": "node scripts/build.js --mode=inline",
    "build:split": "node scripts/build.js --mode=split",
    "dev": "npm run build && npx serve dist -p 3000",
    "lab:synthetic": "node -r sucrase/register scripts/run-synthetic-athlete-lab.js --catalog expanded --count 101 --weeks 26",
    "lab:synthetic:quick": "node -r sucrase/register scripts/run-synthetic-athlete-lab.js --catalog focus --weeks 4",
    "lab:synthetic:matrix": "node -r sucrase/register scripts/run-synthetic-athlete-lab.js --catalog release-gate --weeks 12",
    "qa:adaptive-learning:analyze": "node -r sucrase/register scripts/run-adaptive-learning-analysis.js",
    "qa:adaptive-learning:analyze:fixture": "node -r sucrase/register scripts/run-adaptive-learning-analysis.js --fixture",
    "qa:adaptive-learning:export": "node -r sucrase/register scripts/run-adaptive-learning-export.js",
    "qa:adaptive-policy:shadow-eval": "node -r sucrase/register scripts/run-adaptive-policy-shadow-evaluation.js",
    "qa:adaptive-policy:shadow-eval:fixture": "node -r sucrase/register scripts/run-adaptive-policy-shadow-evaluation.js --fixture",
    "qa:adaptive-policy:promote": "node -r sucrase/register scripts/run-adaptive-policy-promotion.js",
    "qa:adaptive-policy:promote:fixture": "node -r sucrase/register scripts/run-adaptive-policy-promotion.js --fixture",
    "qa:adaptive-policy:launch-readiness": "node -r sucrase/register scripts/run-adaptive-policy-launch-readiness.js",
    "qa:adaptive-policy:launch-readiness:fixture": "node -r sucrase/register scripts/run-adaptive-policy-launch-readiness.js --fixture",
    "qa:launch-simulation": "node -r sucrase/register scripts/run-launch-simulation.js --mode full",
    "qa:launch-simulation:quick": "node -r sucrase/register scripts/run-launch-simulation.js --mode quick",
    "qa:launch-simulation:deployed": "node -r sucrase/register scripts/run-launch-simulation.js --mode deployed",
    "qa:launch-simulation:report": "node -r sucrase/register scripts/run-launch-simulation.js --mode report",
    "qa:launch-simulation:browser:chunk": "node scripts/run-launch-browser-chunk.js",
    "qa:peter-proof-gate": "node scripts/run-peter-proof-gate.cjs",
    "qa:manual-pack": "node scripts/run-manual-qa-pack.cjs",
    "qa:release-gate": "node scripts/run-manual-qa-pack.cjs",
    "bench:goals": "node -r sucrase/register scripts/print-goal-benchmark-summary.cjs",
    "test": "node -r sucrase/register --test tests/*.test.js",
    "test:goal-benchmarks": "node -r sucrase/register --test tests/benchmarks/goal-coverage-benchmark.test.js tests/benchmarks/plan-quality-benchmark.test.js tests/benchmarks/archetype-differentiation.test.js",
    "test:repo-hygiene": "node scripts/check-repo-hygiene.cjs",
    "test:architecture": "node -r sucrase/register --test tests/architecture-boundaries.test.js tests/ux-quality-gates.test.js",
    "test:quality:unit": "node -r sucrase/register --test tests/architecture-boundaries.test.js tests/ux-quality-gates.test.js tests/goal-template-catalog-service.test.js tests/intake-entry-service.test.js tests/auth-entry-service.test.js tests/sync-state-service.test.js tests/launch-persona-generator.test.js tests/launch-simulation-service.test.js tests/benchmarks/goal-coverage-benchmark.test.js tests/benchmarks/plan-quality-benchmark.test.js tests/benchmarks/archetype-differentiation.test.js",
    "test:ux:e2e": "playwright test e2e/ux-quality-gates.spec.js",
    "test:quality:e2e": "playwright test e2e/ux-quality-gates.spec.js e2e/sync-state.spec.js e2e/intake-goal-library.spec.js e2e/launch-simulation-smoke.spec.js",
    "e2e": "playwright test",
    "e2e:sync:staging": "playwright test e2e/real-sync-staging.spec.js --reporter=line",
    "e2e:adversarial": "playwright test e2e/adversarial-trust.spec.js",
    "e2e:adversarial:ci": "playwright test e2e/adversarial-trust.spec.js --reporter=line,html",
    "e2e:headed": "playwright test --headed",
    "e2e:debug": "playwright test --debug",
    "e2e:install": "playwright install chromium",
    "perf:mobile": "node scripts/profile-mobile-performance.cjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.101.1",
    "sucrase": "^3.35.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "serve": "^14.2.6"
  }
}
