{
  "name": "personal-trainer",
  "version": "1.0.0",
  "description": "AI-powered personal training dashboard",
  "scripts": {
    "build": "node scripts/build.js",
    "dev": "npx serve . -p 3000",
    "lab:synthetic": "node -r sucrase/register scripts/run-synthetic-athlete-lab.js",
    "test": "node -r sucrase/register --test tests/*.test.js",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "e2e:debug": "playwright test --debug",
    "e2e:install": "playwright install chromium"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.101.1",
    "sucrase": "^3.35.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "serve": "^14.2.6"
  }
}
